      "use_yn": "Y",
      "adscript_contents": "#ps1_sysnative\n\n$log = 'C:\\Program Files\\Cloudbase Solutions\\Cloudbase-init\\log\\adjoin.log'\necho \"$(Get-Date -format 'u'), Start AD Script\" > $log\n\n# Step 1: Disable Automatic Updates\nsc.exe stop wuauserv | Out-File $log -Append\nsc.exe config wuauserv start=disabled | Out-File $log -Append\necho \"$(Get-Date -format 'u'), Windows Update has been disabled.\" >> $log\n\n# Step 2: Check Current role\necho \"$(Get-Date -format 'u'), Step 2 Check Current Role\" >> $log\nif (!([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] \"Administrator\")) { Start-Process powershell.exe \"-NoProfile -ExecutionPolicy Bypass -File ``\"$PSCommandPath``\"\" -Verb RunAs; exit }\n\n# Step 3: Set Variable for Active Directory Join\necho \"$(Get-Date -format 'u'), Step 3: Set Variable for Active Directory Join\" >> $log\n\n$domain = \"+adDomain+\"\n$domainHead = $domain.split('.')[0].ToUpper()\n$adminId = \"$domainHead\\+adminId+\"\n$adminPw = \"+adminPw+\"\n$vdiOu = \"+vdiOuName+\"\ntry {\n  $credential = new-object -typename System.Management.Automation.PSCredential -argumentlist $adminId, (ConvertTo-SecureString -AsPlainText $adminPw -Force)\n  echo \"$(Get-Date -format 'u'), Start Add-Computer\" >> $log\n  Add-Computer -Domain $domain -Credential $credential -OUPath $vdiOu -ErrorAction Stop | Out-File $log -Append\n  $dUser = net localgroup administrators | Select-String \"Domain Users\"\n  echo \"$(Get-Date -format 'u'), Check Add-Computer Completed, duser : $dUser\" >> $log\n  while(!$dUser){\n    net localgroup administrators \"$domainHead\\Domain Users\" /add\n    $dUser = net localgroup administrators | Select-String \"Domain Users\"\n    if($dUser){break;}\n  }\n  $users = invoke-command { net localgroup administrators | where {$_} | select -skip 4 }\n  $size = $users.Count\n  echo \"$(Get-Date -format 'u'), Local Users Active no\" >> $log\n  For ($i=0; $i -le $size - 2 ; $i++) {\n    $user = $users.Get($i)\n    echo \"$(Get-Date -format 'u'), users : $user\" >> $log\n    if($user -ne \"$domainHead\\Domain Admins\" -and $user -ne \"$domainHead\\Domain Users\") {\n      net user $user /active:no\n    }\n  }\n  Set-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon' -Name 'DefaultDomainName' -Value $domain -Force\n  Set-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon' -Name 'AutoAdminLogon' -Value 0 -Force\n  echo \"$(Get-Date -format 'u'), Restart-Computer\" >> $log\n  shutdown -r -t 0\n} catch {\n  echo \"$(Get-Date -format 'u'), Failed join To Active Directory\" >> $log\n}",
